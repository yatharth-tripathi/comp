{
  "name": "salescontent-ai",
  "version": "0.1.0",
  "private": true,
  "description": "SalesContent AI — AI-powered sales enablement platform for Indian BFSI field sales teams",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter=./apps/* build",
    "dev": "pnpm -r --parallel --filter=./apps/* dev",
    "dev:web": "pnpm --filter @salescontent/web dev",
    "dev:api": "pnpm --filter @salescontent/api dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @salescontent/db generate",
    "db:migrate": "pnpm --filter @salescontent/db migrate",
    "db:push": "pnpm --filter @salescontent/db push",
    "db:studio": "pnpm --filter @salescontent/db studio",
    "clean": "pnpm -r exec rm -rf dist .next .turbo node_modules && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "typescript": "^5.6.3",
    "prettier": "^3.3.3"
  }
}
