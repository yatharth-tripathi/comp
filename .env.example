# =============================================================================
# SalesContent AI — Environment Contract
# =============================================================================
# Copy this to .env at the repo root and fill in real values.
# Services marked REQUIRED must be provisioned before `pnpm dev` will work.
# Services marked OPTIONAL can be stubbed via NODE_ENV=development defaults.
# =============================================================================

# ---- Runtime ----------------------------------------------------------------
NODE_ENV="development"
LOG_LEVEL="info"                       # trace | debug | info | warn | error

# ---- Database (REQUIRED) ----------------------------------------------------
# Create at https://neon.tech — select Mumbai (ap-south-1) region for data residency
DATABASE_URL="postgresql://user:password@ep-xxxx.ap-south-1.aws.neon.tech/salescontent?sslmode=require"

# ---- Auth — email + password (REQUIRED) -------------------------------------
# JWT_SECRET signs/verifies session tokens on BOTH the API (Hono) and the web
# (Next.js middleware + cookie issuer). Must be at least 32 chars; rotate by
# redeploying both services with a new value — every existing session invalidates.
JWT_SECRET="replace-with-openssl-rand-base64-48"
JWT_EXPIRES_IN_SECONDS="604800"       # 7 days
BCRYPT_ROUNDS="12"                    # 10–12 is the modern sweet spot

# ---- AI — Anthropic Claude (REQUIRED) ---------------------------------------
# https://console.anthropic.com — create API key
ANTHROPIC_API_KEY="sk-ant-xxxx"
ANTHROPIC_MODEL_DEFAULT="claude-sonnet-4-5"
ANTHROPIC_MODEL_FAST="claude-haiku-4-5"
# Daily per-tenant spend cap in USD — api enforces this
CLAUDE_DAILY_CAP_USD="25"

# ---- Cache — Upstash Redis (REQUIRED) ---------------------------------------
# https://console.upstash.com — create a Redis DB, pick Mumbai region
UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxx"

# ---- Queue — Upstash QStash (REQUIRED for webhooks + background jobs) -------
QSTASH_URL="https://qstash.upstash.io"
QSTASH_TOKEN="xxxx"
QSTASH_CURRENT_SIGNING_KEY="xxxx"
QSTASH_NEXT_SIGNING_KEY="xxxx"

# ---- Storage — Cloudflare R2 (REQUIRED) -------------------------------------
# https://dash.cloudflare.com/?to=/:account/r2
# Create bucket "salescontent-media" and generate an R2 API token
R2_ACCOUNT_ID="xxxx"
R2_ACCESS_KEY_ID="xxxx"
R2_SECRET_ACCESS_KEY="xxxx"
R2_BUCKET="salescontent-media"
R2_PUBLIC_BASE_URL="https://media.salescontent.ai"  # custom domain bound to the bucket

# ---- Video — Mux (REQUIRED for reels) ---------------------------------------
# https://dashboard.mux.com — create token with Video permissions
MUX_TOKEN_ID="xxxx"
MUX_TOKEN_SECRET="xxxx"
MUX_WEBHOOK_SECRET="xxxx"

# ---- Search — Typesense (REQUIRED) ------------------------------------------
# https://cloud.typesense.org — create a cluster in Singapore or Mumbai
TYPESENSE_HOST="xxxx.a1.typesense.net"
TYPESENSE_PORT="443"
TYPESENSE_PROTOCOL="https"
TYPESENSE_API_KEY="xxxx"
TYPESENSE_SEARCH_ONLY_KEY="xxxx"        # surfaced to the web app for client-side search

# ---- WhatsApp — Meta Cloud API (REQUIRED) -----------------------------------
# https://developers.facebook.com — create a Business App, add WhatsApp product
# Submit the app for review — approval takes 1–3 weeks. Start this TODAY.
WHATSAPP_PHONE_NUMBER_ID="xxxx"
WHATSAPP_BUSINESS_ACCOUNT_ID="xxxx"
WHATSAPP_ACCESS_TOKEN="xxxx"            # permanent system-user token preferred
WHATSAPP_WEBHOOK_VERIFY_TOKEN="pick-a-long-random-string"
WHATSAPP_APP_SECRET="xxxx"              # used to verify webhook signatures

# ---- Observability (OPTIONAL but recommended) -------------------------------
SENTRY_DSN=""
POSTHOG_API_KEY=""
POSTHOG_HOST="https://app.posthog.com"

# ---- Application URLs -------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:8787"
API_INTERNAL_SECRET="pick-a-long-random-string"   # signs server-to-server calls from web to api

# ---- Rate limiting ----------------------------------------------------------
RATE_LIMIT_WINDOW_SECONDS="60"
RATE_LIMIT_MAX_REQUESTS="120"
